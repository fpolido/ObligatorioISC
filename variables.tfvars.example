aws_region   = "us-east-1"
project_name = "ecommerce"
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]
public_subnets     = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnets    = ["10.0.3.0/24", "10.0.4.0/24"]
node_instance_type = "t3.medium"  # mínimo recomendado para correr los 11 servicios
node_min_size      = 2
node_max_size      = 4
node_desired_size  = 2
app_version = "v0.3.9"
db_name           = "ecommercedb"
db_username       = "admin"
db_password       = "CambiarPorOtraContraseña"
db_instance_class = "db.t3.micro"
lab_role_arn = "arn:aws:iam::590183979136:role/LabRole"
